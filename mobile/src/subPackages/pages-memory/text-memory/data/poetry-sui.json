    },
    {
      "id": "sui_006",
      "title": "落叶",
      "author": "孔德绍",
      "dynasty": "隋",
      "dynastyCode": "sui",
      "content": "早秋惊落叶，飘零似客心。翻飞未肯下，犹言惜故林。",
      "contentType": "poetry",
      "tags": [
