      "year": 600
    },
    {
      "id": "sui_007",
      "title": "泛龙舟",
      "author": "杨广",
      "dynasty": "隋",
      "dynastyCode": "sui",
      "content": "舳舻千里泛归舟，言旋旧镇下扬州。借问扬州在何处，淮南江北海西头。",
