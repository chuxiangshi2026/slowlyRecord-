      "year": 580
    },
    {
      "id": "sui_003",
      "title": "野望",
      "author": "杨广",
      "dynasty": "隋",
      "dynastyCode": "sui",
      "content": "寒鸦飞数点，流水绕孤村。斜阳欲落处，一望黯消魂。",
