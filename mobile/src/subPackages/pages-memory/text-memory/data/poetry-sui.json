      "year": 600
    },
    {
      "id": "sui_004",
      "title": "人日思归",
      "author": "薛道衡",
      "dynasty": "隋",
      "dynastyCode": "sui",
      "content": "入春才七日，离家已二年。人归落雁后，思发在花前。",
      "contentType": "poetry",
      "tags": [
        "思乡",
        "名句",
        "薛道衡",
        "五言绝句"
      ],
      "source": "《全隋诗》",
      "location": "长安",
      "wordCount": 20,
      "year": 580
    },
    {
      "id": "sui_005",
      "title": "春江花月夜（其一）",
      "author": "杨广",
      "dynasty": "隋",
      "dynastyCode": "sui",
      "content": "暮江平不动，春花满正开。流波将月去，潮水带星来。",
      "contentType": "poetry",
      "tags": [
