{
  "compilerOptions": {
    "types": [
      "utools-api-types",
      "element-plus/global"
    ],
    "baseUrl": ".",
    // 这里设置基础路径为项目根目录
    "paths": {
      "@/*": [
        "src/*"
      ]
      // 这里设置@符号代表src目录
    }
  },
  "includes": [
    // 如果使用ts或者框架，请添加需要类型提示的文件范围
    // 案例：
    "src/**/*.ts",
    "src/**/*.vue",
    "src/*.vue",
    "preload.js"
  ],
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
